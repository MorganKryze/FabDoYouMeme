# PostgreSQL
POSTGRES_PASSWORD=changeme

# URLs — routed via pangolin reverse proxy
FRONTEND_URL=https://meme.example.com
BACKEND_URL=https://meme.example.com/api

# RustFS
RUSTFS_ENDPOINT=https://rustfs.example.com
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
RUSTFS_BUCKET=fabyoumeme-assets

# SMTP (real credentials required)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=changeme
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@example.com

# App
SEED_ADMIN_EMAIL=admin@example.com

# Legal / privacy policy (shown at /privacy). GDPR Art. 13(1) requires that
# every visitor can see who the controller is and how to contact them. These
# four fields feed directly into the Privacy Policy page at runtime — no
# rebuild needed to change them.
#
# PUBLIC_OPERATOR_NAME — How you want to be identified as the data controller.
#   Individual: "Jane Doe (natural person, non-commercial)"
#   Company:    "Acme Corp S.A.S. (registered in France, SIRET ...)"
PUBLIC_OPERATOR_NAME="Your Name (natural person, non-commercial)"
# PUBLIC_OPERATOR_CONTACT_EMAIL — inbox you monitor for privacy requests
# (access, erasure, rectification). Reuse an existing address; it does not
# need to be separate from your general contact.
PUBLIC_OPERATOR_CONTACT_EMAIL=privacy@example.com
# PUBLIC_OPERATOR_URL — public URL of this instance. Leave empty to default
# to FRONTEND_URL (usually what you want).
PUBLIC_OPERATOR_URL=
# PUBLIC_OPERATOR_SMTP_PROVIDER — free-form description of your SMTP provider,
# for the Art. 28 processor disclosure. Name the company + country/region so
# users know where their email address is being transmitted.
#   Examples:
#     "OVHcloud (OVH SAS, France) — EU-only transactional relay"
#     "Mailgun (US, Sinch Email Inc.) — transactional relay, SCCs in place"
PUBLIC_OPERATOR_SMTP_PROVIDER="Your SMTP provider (company, country)"
