# ============================================================
# Prod stage — public production deployment.
# Copy to .env.prod and fill in REAL values, then run
# `make env-check` to verify drift against this template.
# Every required value must be real before the stack boots;
# placeholders will break magic-link auth and asset uploads.
# ============================================================

# Stage marker. Gates env-specific features — most notably the
# /api/admin/danger/* destructive actions, which are unmounted
# entirely in prod (404, not 403). Legal values: dev, preprod, prod.
# Default when unset is "prod" — fail safe, so leave as "prod" here.
APP_ENV=prod

# Frontend-visible mirror of APP_ENV. SvelteKit only exposes env
# vars prefixed with PUBLIC_ to client code, so the admin sidebar
# and danger zone load function read this to decide whether to
# render the nav link and page. Must match APP_ENV exactly — keep
# as "prod" to hide the danger zone entirely.
PUBLIC_APP_ENV=prod

# PostgreSQL password. Generate a strong value:
#   `openssl rand -base64 32`
# Rotation: change the DB password, update this var, then
# `make prod-down && make prod`. DATABASE_URL is composed at
# runtime in compose.base.yml from POSTGRES_PASSWORD.
POSTGRES_PASSWORD=changeme

# Public URL of the frontend. Must match the host your reverse
# proxy routes `/` to. Used for CORS, WebSocket Origin checks,
# and the magic-link base URL sent in emails.
FRONTEND_URL=https://meme.example.com
# Public URL of the backend API (reverse proxy routes `/api/*`
# here). Must share the same origin as FRONTEND_URL for session
# cookies to work — different subdomains will break auth.
BACKEND_URL=https://meme.example.com/api

# RustFS (S3-compatible) endpoint, reachable from inside the
# Docker network. For co-located RustFS on the `pangolin`
# network, use the internal hostname; otherwise use the public
# https URL.
RUSTFS_ENDPOINT=https://rustfs.example.com
# Access key pair scoped to the prod bucket. Use a service
# account with read/write on this bucket only — never share
# credentials across stages, and never use a root key.
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
# Bucket name — must exist before first boot. The backend does
# not auto-create buckets.
RUSTFS_BUCKET=fabdoyoumeme-assets

# SMTP relay — REAL credentials required. Without a working
# relay, magic-link login is broken and no one can log in.
# Sign a DPA with your provider before launch (GDPR Art. 28);
# see docs/reference/gdpr.md.
SMTP_HOST=smtp.example.com
# 587 (STARTTLS) is the usual default. Use 465 if your provider
# requires implicit TLS. Port 25 is rarely reachable from cloud
# hosts and will silently fail on many ISPs.
SMTP_PORT=587
SMTP_USERNAME=changeme
SMTP_PASSWORD=changeme
# From address — must match (or be authorized by) SMTP_USERNAME,
# otherwise the provider will reject the send. SPF/DKIM for the
# From domain is strongly recommended before launch.
SMTP_FROM=noreply@example.com

# First-boot admin — MUST be a real inbox you control. On first
# start, the backend auto-creates the admin user and sends a
# magic link here; this is the ONLY way to bootstrap admin
# access. If the link reaches a dead address, recovery requires
# manual DB edits (see docs/self-hosting.md).
SEED_ADMIN_EMAIL=admin@example.com

# How you want to be identified as the data controller on the
# /privacy page. GDPR Art. 13(1) requires every visitor can see
# this. Injected at runtime via `$env/dynamic/public` — no
# rebuild needed to change.
#   Individual: "Jane Doe (natural person, non-commercial)"
#   Company:    "Acme Corp S.A.S. (registered in France, SIRET ...)"
PUBLIC_OPERATOR_NAME="Your Name (natural person, non-commercial)"
# Inbox you monitor for privacy requests (access, erasure,
# rectification). Reuse an existing address; it does not need
# to be separate from your general contact.
PUBLIC_OPERATOR_CONTACT_EMAIL=privacy@example.com
# Public URL of this instance. Leave empty to default to
# FRONTEND_URL at runtime (usually what you want). Only override
# if /privacy is served from a different origin than the app.
PUBLIC_OPERATOR_URL=
# Free-form description of your SMTP provider, for the Art. 28
# processor disclosure. Name the company + country/region so
# users know where their email address is being transmitted.
#   Examples:
#     "OVHcloud (OVH SAS, France) — EU-only transactional relay"
#     "Mailgun (US, Sinch Email Inc.) — transactional relay, SCCs in place"
PUBLIC_OPERATOR_SMTP_PROVIDER="Your SMTP provider (company, country)"

# ============================================================
# Optional tuning overrides — all commented out.
# The backend reads these env vars with sensible defaults (see
# docker/compose.base.yml for the full list). Uncomment any you
# want to change. Because these start with `#`, `make env-check`
# does NOT flag them as drift until you uncomment them.
# Full reference: docs/self-hosting.md → Environment variables.
# ============================================================

# Log verbosity: debug | info | warn | error
# LOG_LEVEL=info

# Magic-link token lifetime. Tighter is more secure; 5m–15m is
# typical. Format: Go duration string.
# MAGIC_LINK_TTL=15m

# Session cookie lifetime after login. 720h = 30 days.
# SESSION_TTL=720h

# Grace window for a disconnected player to rejoin a live
# round before being removed from the room.
# RECONNECT_GRACE_WINDOW=30s

# Max upload size in bytes for meme assets (default 2 MiB).
# MAX_UPLOAD_SIZE_BYTES=2097152

# Per-IP rate limits — in-memory, per-process (see ADR-005 in
# docs/reference/decisions.md). If you ever add a second backend
# instance, externalize these to Redis.
# RATE_LIMIT_AUTH_RPM=10
# RATE_LIMIT_ROOMS_RPH=10
# RATE_LIMIT_UPLOADS_RPH=50
# RATE_LIMIT_GLOBAL_RPM=100

# Comma-separated CIDR ranges (or bare IPs) for hops the backend
# should treat as trusted proxies when walking X-Forwarded-For.
# Set this to your internal Docker network's CIDR so the backend
# can resolve real client IPs through the SvelteKit container —
# without it, every guest/anonymous request looks like the same
# IP and shares one rate-limit bucket. Discover the value with
# `docker network inspect <project>_project_network`.
# Full rationale: docs/self-hosting.md → Trusted proxies and rate limiting.
# TRUSTED_PROXIES=172.18.0.0/16
