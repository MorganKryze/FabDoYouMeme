		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^3.2.4",
		"happy-dom": "^20.8.9",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"lucide-svelte": "^1.0.1"
	}
