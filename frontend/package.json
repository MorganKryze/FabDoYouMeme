{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "npm run i18n:check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"i18n:check": "node scripts/i18n-check.mjs"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.16.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^3.2.4",
		"happy-dom": "^20.9.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.9",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"lucide-svelte": "^1.0.1"
	},
