# ============================================================
# Preprod stage — real staging deployment used for release
# rehearsal and trusted-tester access. Isolated Postgres, RustFS,
# and SMTP from prod. Do NOT use for untrusted public traffic.
# Copy to .env.preprod and fill in real values, then run
# `make env-check` to verify drift against this template.
# ============================================================

# Stage marker. Gates env-specific features — most notably the
# /api/admin/danger/* destructive actions, which are unmounted
# entirely in prod (404, not 403). Legal values: dev, preprod, prod.
# Default when unset is "prod" — fail safe.
APP_ENV=preprod

# Frontend-visible mirror of APP_ENV. SvelteKit only exposes env
# vars prefixed with PUBLIC_ to client code, so the admin sidebar
# and danger zone load function read this to decide whether to
# render the nav link and page. Must match APP_ENV exactly.
PUBLIC_APP_ENV=preprod

# PostgreSQL password. Generate a strong value — no placeholders.
# Suggestion: `openssl rand -base64 32`.
POSTGRES_PASSWORD=changeme

# Public URL of the frontend. Must match the host your reverse
# proxy routes `/` to. Used for CORS, WebSocket Origin checks,
# and the magic-link base URL sent in emails.
FRONTEND_URL=https://meme.example.com
# Public URL of the backend API (reverse proxy routes `/api/*`
# here). Must share the same origin as FRONTEND_URL for session
# cookies to work — different subdomains will break auth.
BACKEND_URL=https://meme.example.com/api

# RustFS (S3-compatible) endpoint, reachable from inside the
# container network. If RustFS runs on a separate stack attached
# to `pangolin`, use its internal hostname; otherwise use the
# public https URL.
RUSTFS_ENDPOINT=https://rustfs.example.com
# Access key pair scoped to the preprod bucket. Do NOT reuse prod
# keys — stage isolation protects prod if a preprod key leaks.
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
# Bucket name — must exist before first boot. Create it with
# `mc mb myalias/fabdoyoumeme-assets-preprod` or via the RustFS UI.
RUSTFS_BUCKET=fabdoyoumeme-assets

# SMTP relay — real credentials required. Magic-link login is
# broken without a working relay, so no one can log in. Signing
# a DPA with your provider is recommended before inviting
# external testers (see docs/reference/gdpr.md).
SMTP_HOST=smtp.example.com
# 587 (STARTTLS) is the usual default. Use 465 if your provider
# requires implicit TLS. Port 25 is rarely reachable from cloud
# hosts and will silently fail on many ISPs.
SMTP_PORT=587
SMTP_USERNAME=changeme
SMTP_PASSWORD=changeme
# From address — must match (or be authorized by) SMTP_USERNAME,
# otherwise the provider will reject the send. SPF/DKIM for the
# From domain is strongly recommended.
SMTP_FROM=noreply@example.com

# First-boot admin — MUST be a real inbox you control. On first
# start, the backend auto-creates the admin user and sends a
# magic link here. If the link reaches a dead address, recovery
# requires manual DB edits (see docs/self-hosting.md).
SEED_ADMIN_EMAIL=admin@example.com

# How you want to be identified as the data controller on the
# /privacy page. GDPR Art. 13(1) requires visitors can see this.
# For preprod, clearly label the environment as staging so
# testers don't mistake it for the production disclosure.
#   Individual: "Jane Doe (natural person, non-commercial)"
#   Company:    "Acme Corp S.A.S. (registered in France, SIRET ...)"
PUBLIC_OPERATOR_NAME="Your Name (preprod / staging)"
# Inbox you monitor for privacy requests (access, erasure,
# rectification). Reuse an existing address — no need to keep
# it separate from your general contact.
PUBLIC_OPERATOR_CONTACT_EMAIL=privacy@example.com
# Public URL of this instance. Leave empty to default to
# FRONTEND_URL at runtime — usually what you want.
PUBLIC_OPERATOR_URL=
# Free-form description of your SMTP provider, for the Art. 28
# processor disclosure. Name the company + country/region so
# users know where their email address is being transmitted.
#   Examples:
#     "OVHcloud (OVH SAS, France) — EU-only transactional relay"
#     "Mailgun (US, Sinch Email Inc.) — transactional relay, SCCs in place"
PUBLIC_OPERATOR_SMTP_PROVIDER="Your SMTP provider (company, country)"
