# ============================================================
# Dev stage — local only, uses Mailpit for email capture.
# Copy to .env.dev and customize. `make dev` loads this file.
# Safe defaults below — no secrets leave your host.
# ============================================================

# Password for the isolated dev Postgres volume. Any value works;
# the dev volume (fabyoumeme-dev_postgres_data) is scoped per stage.
POSTGRES_PASSWORD=devpassword

# Public URL of the frontend — used for CORS and the magic-link
# base URL. Dev exposes port 3000 on localhost via compose.dev.yml.
FRONTEND_URL=http://localhost:3000
# Public URL of the backend API. Dev publishes port 8080 directly
# for ad-hoc curl probing; change only if you remapped it.
BACKEND_URL=http://localhost:8080

# RustFS (S3-compatible) endpoint, reachable from inside the
# Docker network. Even in dev, the backend needs a live bucket to
# accept meme uploads — point at your own dev RustFS or a shared
# staging bucket.
RUSTFS_ENDPOINT=https://rustfs.example.com
# Access / secret key pair scoped to the bucket below.
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
# Bucket must exist — create with `mc mb myalias/fabyoumeme-assets`
# or via the RustFS web UI before first boot.
RUSTFS_BUCKET=fabyoumeme-assets

# First-boot admin inbox. On first startup the backend creates the
# admin user and sends a magic link here. In dev, Mailpit captures
# it at http://localhost:8025 — any placeholder address works.
SEED_ADMIN_EMAIL=admin@example.com

# Privacy policy fields served at /privacy. Dev placeholders, NOT
# GDPR-compliant. See .env.prod.example for production guidance
# on each of these four variables.
PUBLIC_OPERATOR_NAME="Dev Operator (local only)"
# Inbox shown to visitors for privacy requests. Any placeholder in dev.
PUBLIC_OPERATOR_CONTACT_EMAIL=dev@localhost
# Leave empty to default to FRONTEND_URL at runtime.
PUBLIC_OPERATOR_URL=
# Processor disclosure string. Dev uses Mailpit — nothing actually
# leaves the host, so label it that way for transparency.
PUBLIC_OPERATOR_SMTP_PROVIDER="Mailpit (local dev — no data leaves host)"

# SMTP is overridden by compose.dev.yml to target the Mailpit
# sidecar. Leaving these blank is intentional — they exist only so
# `make env-check` sees all keys declared on both sides.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
