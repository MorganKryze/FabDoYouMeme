# PostgreSQL
POSTGRES_PASSWORD=devpassword

# URLs — local access via forwarded ports
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# RustFS (S3-compatible storage)
RUSTFS_ENDPOINT=https://rustfs.example.com
RUSTFS_ACCESS_KEY=changeme
RUSTFS_SECRET_KEY=changeme
RUSTFS_BUCKET=fabyoumeme-assets

# App
SEED_ADMIN_EMAIL=admin@example.com

# The following SMTP vars are overridden by compose.dev.yml (mailpit)
# and do not need real values for local dev.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
